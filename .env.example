# Required: Anthropic API Key for Claude Agent SDK
ANTHROPIC_API_KEY="your-key-here"

# Required: OpenRouter API key for ADK agents
OPENROUTER_API_KEY="your-key-here"

# Model configuration (defaults shown)
DEFAULT_MODEL="google/gemini-2.5-pro"
CODING_MODEL="claude-sonnet-4-5-20250929" # Has to be Anthropic Model available in Claude Code
REVIEW_MODEL="google/gemini-2.5-pro"

# OpenRouter configuration (defaults shown)
OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
OR_SITE_URL="ai-research-engineer"
OR_APP_NAME="AI Research Engineer"

# Context7 API Key for enhanced documentation access
CONTEXT7_API_KEY="your-key-here"

# Semantic Scholar API Key
SEMANTIC_SCHOLAR_API_KEY="your-key-here"

#GITHUB Token
GITHUB_PAT="your-key-here"

# Hugging Face Token
HF_TOKEN="your-key-here"

# Server authentication
# Set this to a long random secret to protect POST /api/sessions and
# POST /api/submissions.  If unset, those endpoints are unauthenticated
# (a warning is logged on startup).
# ARCHIMEDES_API_TOKEN="your-secret-token-here"

# CORS allowed origins (comma-separated).
# Defaults to localhost:3000 and localhost:8000 when not set.
# ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.example.com"

# Optional: Disable network access
# DISABLE_NETWORK_ACCESS=true